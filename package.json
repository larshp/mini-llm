{
  "name": "mini-llm",
  "version": "0.1.0",
  "private": true,
  "description": "Run a small quantized LLM locally in Node.js, within ~4 GB of RAM. Pure npm install — no node-gyp, no build tools.",
  "type": "module",
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "pull-model": "node --env-file-if-exists=.env src/pull-model.js",
    "abap-model-survey": "node src/abap-model-survey.js",
    "chat": "node --env-file-if-exists=.env src/chat.js",
    "serve": "node --env-file-if-exists=.env src/server.js",
    "start": "npm run chat"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "overrides": {
    "adm-zip": "^0.6.0"
  }
}
