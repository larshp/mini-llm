# Copy to .env to override defaults. `npm run chat/serve` load .env automatically.

# Hugging Face ONNX model id (see README for other 4 GB-friendly options).
MODEL_ID=onnx-community/Qwen2.5-0.5B-Instruct

# Weight precision: q4 | q4f16 | q8 | int8 | uint8 | bnb4 | fp16 | fp32
MODEL_DTYPE=q4

# Where models are cached (first run downloads here).
MODELS_DIR=./models

# Assistant behaviour.
SYSTEM_PROMPT=You are a helpful, concise assistant running locally on the user's machine.
MAX_TOKENS=512
TEMPERATURE=0.7
TOP_P=0.9
REPETITION_PENALTY=1.1

# HTTP server (npm run serve).
HOST=127.0.0.1
PORT=8080
